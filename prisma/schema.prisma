// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id               String   @id @default(cuid())
  name             String
  techNotes        Json?
  isActive         Boolean  @default(true)
  archivedAt       DateTime?
  orders           Order[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([isActive])
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model PlateType {
  id                String          @id @default(cuid())
  format            String
  manufacturer      String
  otherParams       Json?
  minStockThreshold Int             @default(0)
  areaSqm           Float?
  isActive          Boolean         @default(true)
  archivedAt        DateTime?
  movements         PlateMovement[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([isActive])
}

model Order {
  id                String           @id
  clientId          String
  client            Client           @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  status            OrderStatus      @default(NEW)
  clientOrderNum    String?
  plateFormat       String           @default("")
  totalPlates       Int              @default(0)
  notesSnapshot     Json?
  plateMovements    PlateMovement[]
  processControls   ProcessControl[]
  developerBatchId  String?
  developerBatch    DeveloperBatch?  @relation(fields: [developerBatchId], references: [id])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([clientOrderNum])
  @@index([status])
}

model ProcessControl {
  id                String           @id @default(cuid())
  orderId           String
  order             Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  measurements      Json             @default("[]")
  speed             Float?
  temperature       Float?
  notes             String?
  developerBatchId  String?
  developerBatch    DeveloperBatch?  @relation(fields: [developerBatchId], references: [id])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model PlateMovement {
  id             String        @id @default(cuid())
  plateTypeId    String
  plateType      PlateType     @relation(fields: [plateTypeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  quantity       Int
  movementType   MovementType
  reason         MovementReason
  responsibility Responsibility?
  orderId        String?
  order          Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  writeOffCount  Int?
  createdAt      DateTime       @default(now())

  @@index([plateTypeId])
  @@index([orderId])
}

model EventLog {
  id          String   @id @default(cuid())
  eventType   String
  context     String
  payload     Json
  timestamp   DateTime @default(now())

  @@index([timestamp])
}

model DeveloperBatch {
  id               String           @id @default(cuid())
  startedAt        DateTime         @default(now())
  volumeLiters     Float
  concentrateName  String?
  concentrateRatio String?
  maxAreaSqm       Float?
  notes            String?
  isActive         Boolean          @default(true)
  endedAt          DateTime?

  orders           Order[]
  processControls  ProcessControl[]

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

enum OrderStatus {
  NEW
  PROCESS
  DONE
}

enum MovementType {
  INCOMING
  OUTGOING
}

enum MovementReason {
  PURCHASE
  RETURN
  CORRECTION
  NORMAL_USAGE
  SCRAP_CLIENT
  SCRAP_PRODUCTION
  SCRAP_MATERIAL
  LOSS_TEST
  LOSS_CALIBRATION
  LOSS_EQUIPMENT
}

enum Responsibility {
  CLIENT
  PRODUCTION
  MATERIALS
}